# HTTP
HTTP_ADDR=:8080
CORS_ORIGINS=*

# OnlinePBX — MUSTAQIL rejim (token avtomatik yangilanadi)
ONPBX_DOMAIN=pbx12127.onpbx.ru
ONPBX_BASE=https://api2.onlinepbx.ru

# OnlinePBX panel -> Sozlamalar -> API'dagi yagona API-kalit (auth_key).
# Backend buni auth.json'ga yuborib, token (key_id:key) oladi va yangilab turadi.
# WebSocket kaliti ham shu API-kalitning o'zi.
ONPBX_API_KEY=

# Postgres
DATABASE_URL=postgres://monitoring:monitoring@localhost:5432/monitoring?sslmode=disable

# Sync
SYNC_INTERVAL=120s
SYNC_LOOKBACK=24h
HISTORY_LIMIT=2000
