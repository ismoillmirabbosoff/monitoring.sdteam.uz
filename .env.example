# HTTP
HTTP_ADDR=:8080
CORS_ORIGINS=*

# OnlinePBX — MUSTAQIL rejim (hech qanday proxy/phone.sddev.uz YO'Q)
ONPBX_DOMAIN=pbx12127.onpbx.ru
ONPBX_BASE=https://api2.onlinepbx.ru

# 1-variant (hozir): to'g'ridan-to'g'ri sessiya tokeni (key_and_id) + websocket kaliti
ONPBX_STATIC_TOKEN=<key>:<key_id>
ONPBX_WS_KEY=<auth_key>

# 2-variant (TAVSIYA, muddatsiz): OnlinePBX kabineti -> Sozlamalar -> API'dan
# xom api_key/api_id. Bular bo'lsa backend tokenni o'zi yangilab turadi,
# ONPBX_STATIC_TOKEN keraksiz bo'ladi:
# ONPBX_API_KEY=
# ONPBX_API_ID=

# Postgres
DATABASE_URL=postgres://monitoring:monitoring@localhost:5432/monitoring?sslmode=disable

# Sync
SYNC_INTERVAL=120s
SYNC_LOOKBACK=24h
HISTORY_LIMIT=2000
